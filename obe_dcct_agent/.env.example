# OBE DCCT Agent - Environment Variables
# Copy this file to .env and fill in your actual values. DO NOT commit .env.

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small

# ── Qdrant Vector DB ────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=obe_dcct

# ── OBE Thresholds ─────────────────────────────────────────────────────────────
MIN_CLO_COUNT=3
MAX_CLO_COUNT=8
MIN_CONFIDENCE_SCORE=0.75

# ── IRMA Weights ───────────────────────────────────────────────────────────────
IRMA_WEIGHT_I=0.40
IRMA_WEIGHT_R=0.25
IRMA_WEIGHT_M=0.15
IRMA_WEIGHT_A=0.20

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
