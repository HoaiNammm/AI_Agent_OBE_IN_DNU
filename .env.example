# Environment Configuration Template
# Copy file này thành .env và điền API keys thực

# ============================================================
# LLM API Keys (cần ít nhất 1 trong 2)
# ============================================================

# Google Gemini API Key (https://aistudio.google.com)
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic Claude API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================
# Optional: Qdrant Cloud (nếu dùng hosted vector store)
# Mặc định: dùng in-memory Qdrant (không cần cấu hình)
# ============================================================

# QDRANT_URL=https://your-cluster.qdrant.tech
# QDRANT_API_KEY=your_qdrant_api_key_here

# ============================================================
# App Settings (tùy chọn)
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Max retries mỗi bước
MAX_RETRIES=2
